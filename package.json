{
  "name": "shinkansen-tests",
  "version": "0.0.1",
  "private": true,
  "description": "Shinkansen Chrome Extension 的 Playwright 自動化測試 harness",
  "type": "module",
  "scripts": {
    "build:chrome": "node scripts/build.js chrome",
    "build:firefox": "node scripts/build.js firefox",
    "build:all": "node scripts/build.js chrome && node scripts/build.js firefox",
    "test": "playwright test",
    "test:regression": "playwright test test/regression/",
    "test:unit": "playwright test test/unit/",
    "test:version": "playwright test test/version-check.spec.js",
    "test:jest": "jest --config jest.config.cjs",
    "test:all": "playwright test && jest --config jest.config.cjs",
    "test:chrome": "EXTENSION_DIR=build/chrome playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "esbuild": "^0.25.0",
    "jest": "^29.7.0",
    "jsdom": "^25.0.1"
  }
}
